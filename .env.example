# ─────────────────────────────────────────────
# Predicta Discovery — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.

# Anthropic API Key
# Get this from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API Key (for email delivery)
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# The "from" address for outbound emails
# Must be a verified domain in Resend (e.g. hello@predicta.au)
RESEND_FROM_EMAIL=hello@predicta.au

# Your name — shown in email from field
RESEND_FROM_NAME=Louis Nonis

# BCC address — every report sent to user also copies you
# Set to your own email to receive every lead
LEAD_BCC_EMAIL=louis@predicta.au

# Site URL — used for links in emails
NEXT_PUBLIC_SITE_URL=https://predicta.au
